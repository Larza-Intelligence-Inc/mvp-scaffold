# The env-var CONTRACT. In local dev, docker-compose fills these in.
# In hosting (Railway, your own cloud), the SAME keys get filled from that
# platform's secret store. App code only ever reads these names — never hardcodes.
DATABASE_URL=postgres://app:dev@db:5432/app
# Frontend proxies browser `/api/*` calls to this internal backend URL (server-side).
# The browser never needs a public API URL — no NEXT_PUBLIC_* API var required.
BACKEND_URL_INTERNAL=http://backend:3001
FRONTEND_ORIGIN=http://localhost:3000
# Backend Better Auth (generate a unique secret for real deployments)
BETTER_AUTH_SECRET=replace-with-openssl-rand-base64-32
BETTER_AUTH_URL=http://localhost:3001
# WebAuthn relying party — must match the browser-visible hostname (frontend).
# Defaults to FRONTEND_ORIGIN's hostname when unset.
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=Larza
# Resend (email). Required for POST /api/send and auth transactional email.
RESEND_API_KEY=re_xxxxxxxxx
# Optional override; defaults to Resend onboarding sender.
EMAIL_FROM=Acme <onboarding@resend.dev>
# Optional recipient for live email e2e tests (Resend test-mode often restricts this).
AUTH_EMAIL_TEST_TO=you@example.com
