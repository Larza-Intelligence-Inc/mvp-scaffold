{
  "name": "api",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start:prod": "tsx src/index.ts",
    "build": "tsc",
    "openapi:emit": "tsx scripts/emit-openapi.ts",
    "test:resend": "tsx --test src/resend-basic-send.e2e.test.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push --force",
    "db:studio": "drizzle-kit studio --host 0.0.0.0 --port 4983"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.23",
    "@better-auth/passkey": "^1.6.23",
    "@hono/node-server": "^1.13.0",
    "@hono/swagger-ui": "^0.5.0",
    "@hono/zod-openapi": "^0.18.0",
    "better-auth": "^1.6.23",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.6.0",
    "postgres": "^3.4.0",
    "resend": "^6.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "drizzle-kit": "^0.31.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
